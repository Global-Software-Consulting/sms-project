# NextAuth Configuration
NEXTAUTH_URL=https://app.bestsmshq.com
NEXTAUTH_SECRET=your-super-secret-key-here-generate-with-openssl-rand-base64-32

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Database (for production)
DATABASE_URL=postgresql://user:password@localhost:5432/sms_platform

# Backend API
NEXT_PUBLIC_API_URL=https://api.bestsmshq.com/api/v1

# Public site URL (used for canonical URLs, OG tags, sitemap, robots.txt)
# No trailing slash. Required for production SEO.
NEXT_PUBLIC_SITE_URL=https://app.bestsmshq.com


